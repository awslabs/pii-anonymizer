# AWS Region (must match your deployment)
AWS_REGION=us-east-2

# S3 buckets
INPUT_BUCKET=your-input-bucket-name
OUTPUT_BUCKET=your-output-bucket-name
INPUT_PREFIX=pii_data/
OUTPUT_PREFIX=redacted/

# DynamoDB table name (from CloudFormation/Terraform outputs)
DYNAMODB_TABLE_NAME=PII-Anonymizer-MappingRegistry

# Config (S3-backed pipeline settings — enables Settings panel in sidebar)
CONFIG_BUCKET=your-artifact-bucket-name
CONFIG_KEY=config/config.yaml
